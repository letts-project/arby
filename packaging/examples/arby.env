# /etc/arby/arby.env — environment for the arby systemd service.
# Installed as arby.env.example; copy to /etc/arby/arby.env, set ownership to
# arby:arby and perms 0600, then edit.
#
# arby reads the cluster topology from letts.yaml. Recommended: reference admin
# tokens as ${ENV} inside letts.yaml and define the secrets here — then letts.yaml
# carries no secrets and arby (a non-root user) can read it without 0600.
#
# Example (in letts.yaml):  admin_token: ${LETTS_ADMIN_TOKEN}
# LETTS_ADMIN_TOKEN=replace-me

# Path to the cluster config. arby also auto-discovers /etc/letts/letts.yaml.
LETTS_CONFIG=/etc/letts/letts.yaml

# Extra arby flags — the service runs:  arby $ARBY_OPTS
# Default binds loopback; put arby behind a reverse proxy for authentication.
ARBY_OPTS=--listen 127.0.0.1:8080 --theme light
